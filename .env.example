# =============================================================================
# Office Detective - Environment Configuration
# =============================================================================
# Copy this file to .env and apps/api/.env, then configure your values.
# Most defaults work out of the box with Docker Compose.

# Application
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production-min-32-chars

# -----------------------------------------------------------------------------
# PostgreSQL (pgvector)
# -----------------------------------------------------------------------------
POSTGRES_USER=detective
POSTGRES_PASSWORD=detective_secret
POSTGRES_DB=office_detective
POSTGRES_TEST_DB=office_detective_test
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Neo4j (Knowledge Graph)
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=detective_graph

# -----------------------------------------------------------------------------
# Redis (Cache)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# OpenAI (Required for AI features)
# -----------------------------------------------------------------------------
# Get your API key at: https://platform.openai.com/api-keys
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_API_BASE=
OPENAI_MODEL=gpt-4o
LLM_FALLBACK_PROVIDER=deepseek
LLM_REQUEST_TIMEOUT_SECONDS=40
LLM_MAX_RETRIES=2

# -----------------------------------------------------------------------------
# DeepSeek (Optional LLM provider)
# -----------------------------------------------------------------------------
# If using DeepSeek, set LLM_PROVIDER=deepseek and configure values below.
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# -----------------------------------------------------------------------------
# Embeddings (OpenAI-compatible endpoint)
# -----------------------------------------------------------------------------
# By default, embeddings reuse OPENAI_API_KEY.
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=
EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# API Rate Limiting
# -----------------------------------------------------------------------------
CHAT_RATE_LIMIT_REQUESTS=20
CHAT_RATE_LIMIT_WINDOW_SECONDS=60
HINT_RATE_LIMIT_REQUESTS=10
HINT_RATE_LIMIT_WINDOW_SECONDS=60

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
# Internal API URL used by server-side rendering (optional)
API_URL_INTERNAL=

# -----------------------------------------------------------------------------
# CORS (comma-separated origins)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
